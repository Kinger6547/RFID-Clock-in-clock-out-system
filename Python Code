# =============================================================================
# LOCAL BACKUP
# =============================================================================

def log_local(user, action):
    try:
        with open("backup.csv", "a", newline="") as f:
            writer = csv.writer(f)
            writer.writerow([user, action, datetime.datetime.now().isoformat()])
    except Exception as e:
        print("Local backup failed:", e)


# =============================================================================
# STATE
# =============================================================================

active_timers = {}   # {name: True} — who is currently clocked in
daily_log     = {}   # {name_date: True} — prevents double clock-ins per day
start_times   = {}   # {name: datetime} — for duration calculation
terminal_log  = []   # Last 200 lines shown on web terminal
sound_queue   = []   # Sounds to play: "in", "out", or "master"


# =============================================================================
# HELPERS
# =============================================================================

def today():
    return datetime.date.today().isoformat()

def today_display():
    return datetime.date.today().strftime("%b %d")

def timestamp():
    return datetime.datetime.now().strftime("%H:%M:%S")

def day_name():
    return datetime.datetime.now().strftime("%A")

def format_duration(seconds):
    hours   = int(seconds // 3600)
    minutes = int((seconds % 3600) // 60)
    return f"{hours}h {minutes:02d}m"

def add_duration_seconds(existing_str, new_seconds):
    try:
        parts = existing_str.replace("h", "").replace("m", "").split()
        existing_seconds = int(parts[0]) * 3600 + int(parts[1]) * 60
    except:
        existing_seconds = 0
    return format_duration(existing_seconds + new_seconds)

def add_log(message, sound=None):
    line = f"[{timestamp()}] {message}"
    terminal_log.append(line)
    print(line)
    if len(terminal_log) > 200:
        terminal_log.pop(0)
    if sound:
        sound_queue.append(sound)


# =============================================================================
# CLOCK IN / CLOCK OUT
# =============================================================================

def clock_in(user):
    key = f"{user}_{today()}"
    if key in daily_log:
        add_log(f"{user} already logged today — tap again to clock out")
        return

    active_timers[user] = True
    start_times[user]   = datetime.datetime.now()
    daily_log[key]      = True

    log_local(user, "IN")
    log_clockin_to_sheet(user)
    update_live_status()
    add_log(f"{user} — CLOCKED IN", sound="in")

def clock_out(user):
    if user not in active_timers:
        return

    duration_seconds = 0
    if user in start_times:
        duration_seconds = (datetime.datetime.now() - start_times[user]).total_seconds()
        del start_times[user]

    del active_timers[user]

    log_local(user, "OUT")
    log_clockout_to_sheet(user, duration_seconds)
    update_season_summary(user, duration_seconds)
    update_live_status()
    add_log(f"{user} — CLOCKED OUT ({format_duration(duration_seconds)})", sound="out")

def clock_out_all():
    add_log("MASTER CARD — STOPPING ALL ACTIVE TIMERS", sound="master")
    for u in list(active_timers.keys()):
        clock_out(u)


# =============================================================================
# GOOGLE SHEETS — LOG TAB
# =============================================================================

def log_clockin_to_sheet(user):
    if not USE_SHEETS or sheet_log is None:
        return
    try:
        sheet_log.append_row([
            user, today(), day_name(),
            datetime.datetime.now().strftime("%H:%M:%S"), "", ""
        ])
    except Exception as e:
        add_log(f"Sheet clock-in log failed: {e}")

def log_clockout_to_sheet(user, duration_seconds):
    if not USE_SHEETS or sheet_log is None:
        return
    try:
        clock_out_time = datetime.datetime.now().strftime("%H:%M:%S")
        duration_str   = format_duration(duration_seconds)
        all_rows = sheet_log.get_all_values()
        for i, row in enumerate(reversed(all_rows)):
            row_index = len(all_rows) - i
            if row[0] == user and row[1] == today() and len(row) >= 5 and row[4] == "":
                sheet_log.update_cell(row_index, 5, clock_out_time)
                sheet_log.update_cell(row_index, 6, duration_str)
                return
        sheet_log.append_row([user, today(), day_name(), "", clock_out_time, duration_str])
    except Exception as e:
        add_log(f"Sheet clock-out log failed: {e}")


# =============================================================================
# GOOGLE SHEETS — LIVE STATUS TAB
# =============================================================================

def update_live_status():
    if not USE_SHEETS or sheet_live is None:
        return
    try:
        sheet_live.resize(rows=1)
        sheet_live.resize(rows=100)

        now_dt  = datetime.datetime.now()
        updated = now_dt.strftime("%H:%M:%S")

        if not active_timers:
            sheet_live.append_row(["— All clocked out —", "", "", today(), updated])
            return

        for user in active_timers:
            clock_in_dt = start_times.get(user)
            if clock_in_dt:
                elapsed         = (now_dt - clock_in_dt).total_seconds()
                duration_so_far = format_duration(elapsed)
                clock_in_str    = clock_in_dt.strftime("%H:%M:%S")
            else:
                duration_so_far = ""
                clock_in_str    = ""
            sheet_live.append_row([user, clock_in_str, duration_so_far, today(), updated])

    except Exception as e:
        add_log(f"Live status update failed: {e}")


# =============================================================================
# GOOGLE SHEETS — SEASON SUMMARY TAB
# =============================================================================

def update_season_summary(user, duration_seconds):
    if not USE_SHEETS or sheet_summary is None:
        return
    if not in_season():
        add_log(f"Note: {user} clocked out before season start — not in season summary")
        return

    try:
        day        = day_name()
        date_label = today_display()
        day_col    = {"Monday": 2, "Tuesday": 3, "Thursday": 4, "Saturday": 5}
        all_rows   = sheet_summary.get_all_values()

        found_row   = None
        found_index = None
        for i, row in enumerate(all_rows[1:], start=2):
            if row[0] == user:
                found_row   = row
                found_index = i
                break

        if found_row is None:
            new_row = [user, "", "", "", "", "", 1, format_duration(duration_seconds)]
            if day in day_col:
                new_row[day_col[day] - 1] = date_label
            else:
                new_row[5] = date_label
            sheet_summary.append_row(new_row)
        else:
            if day in day_col:
                col_idx        = day_col[day]
                existing_dates = found_row[col_idx - 1] if len(found_row) >= col_idx else ""
                updated_dates  = f"{existing_dates}, {date_label}".strip(", ") if existing_dates else date_label
                sheet_summary.update_cell(found_index, col_idx, updated_dates)
            else:
                existing_other = found_row[5] if len(found_row) > 5 else ""
                updated_other  = f"{existing_other}, {date_label}".strip(", ") if existing_other else date_label
                sheet_summary.update_cell(found_index, 6, updated_other)

            existing_days = int(found_row[6]) if len(found_row) > 6 and found_row[6].isdigit() else 0
            sheet_summary.update_cell(found_index, 7, existing_days + 1)

            existing_total = found_row[7] if len(found_row) > 7 else "0h 00m"
            sheet_summary.update_cell(found_index, 8, add_duration_seconds(existing_total, duration_seconds))

    except Exception as e:
        add_log(f"Season summary update failed: {e}")


# =============================================================================
# MIDNIGHT AUTO-CLOCKOUT
# =============================================================================

def midnight_watcher():
    while True:
        now_dt        = datetime.datetime.now()
        next_midnight = (now_dt + datetime.timedelta(days=1)).replace(
            hour=0, minute=0, second=5, microsecond=0
        )
        time.sleep((next_midnight - now_dt).total_seconds())

        if active_timers:
            add_log("MIDNIGHT — Auto-clocking out all active timers", sound="master")
            for u in list(active_timers.keys()):
                clock_out(u)
        else:
            add_log("MIDNIGHT — No active timers")


# =============================================================================
# PROCESS TAG
# =============================================================================

def process_tag(tag):
    tag = tag.strip()
    if not tag:
        return
    if tag == MASTER_TAG:
        clock_out_all()
        return
    if tag not in USER_TAGS:
        return  # Unknown card — silently ignored
    user = USER_TAGS[tag]
    if user in active_timers:
        clock_out(user)
    else:
        clock_in(user)


