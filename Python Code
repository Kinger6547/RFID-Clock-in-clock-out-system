<script>
    const input    = document.getElementById('hidden-input');
    const logLines = document.getElementById('log-lines');
    let buffer = '', lastLines = [];

    const AudioContext = window.AudioContext || window.webkitAudioContext;
    let audioCtx = null;

    function getAudioCtx() {
        if (!audioCtx) audioCtx = new AudioContext();
        return audioCtx;
    }

    function beep(freq, duration, volume = 0.3) {
        try {
            const ctx  = getAudioCtx();
            const osc  = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.connect(gain);
            gain.connect(ctx.destination);
            osc.frequency.value = freq;
            osc.type = 'sine';
            gain.gain.setValueAtTime(volume, ctx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + duration / 1000);
            osc.start(ctx.currentTime);
            osc.stop(ctx.currentTime + duration / 1000);
        } catch(e) {}
    }

    function soundIn()     { beep(880, 120); setTimeout(() => beep(1100, 180), 130); }
    function soundOut()    { beep(660, 120); setTimeout(() => beep(440,  200), 130); }
    function soundMaster() { beep(550, 100); setTimeout(() => beep(550, 100), 120); setTimeout(() => beep(550, 200), 240); }

    function playSound(type) {
        if (type === 'in')     soundIn();
        if (type === 'out')    soundOut();
        if (type === 'master') soundMaster();
    }

    function keepFocus() { input.focus(); }
    document.addEventListener('click', keepFocus);
    document.addEventListener('keydown', keepFocus);
