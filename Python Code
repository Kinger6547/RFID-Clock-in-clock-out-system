# =============================================================================
# SEASON CONFIG
# -----------------------------------------------------------------------------
# Season runs Jan 10 - Dec 31. Resets every January 1st.
# Change SEASON_START_MONTH and SEASON_START_DAY to adjust the season start.
# =============================================================================

SEASON_START_MONTH = 1
SEASON_START_DAY   = 10

def in_season():
    today = datetime.date.today()
    return today >= datetime.date(today.year, SEASON_START_MONTH, SEASON_START_DAY)

def season_year():
    return str(datetime.date.today().year)


