            const tag = buffer.trim();
            buffer = ''; input.value = '';
            if (tag) sendTag(tag);
        } else {
            buffer += e.key === 'Backspace' ? '' : (e.key.length === 1 ? e.key : '');
        }
    });

    function sendTag(tag) {
        fetch('/scan', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tag: tag })
        });
    }

    function pollLog() {
        fetch('/log')
            .then(r => r.json())
            .then(data => {
                const lines  = data.lines;
                const sounds = data.sounds;

                if (sounds && sounds.length > 0) sounds.forEach(s => playSound(s));

                const changed = lines.length !== lastLines.length ||
                                lines[lines.length-1] !== lastLines[lastLines.length-1];
                if (changed) {
                    renderLines(lines);
                    lastLines = lines;
                }
            })
            .catch(() => {})
            .finally(() => setTimeout(pollLog, 500));
    }

    function renderLines(lines) {
        logLines.innerHTML = '';
        lines.forEach(line => {
            const div = document.createElement('div');
            div.className = 'line ' + getClass(line);
            div.textContent = line;
            logLines.appendChild(div);
        });
        logLines.scrollTop = logLines.scrollHeight;
    }

    function getClass(line) {
        if (line.includes('CLOCKED IN'))                          return 'in';
        if (line.includes('CLOCKED OUT'))                         return 'out';
        if (line.includes('ERROR') || line.includes('UNKNOWN'))   return 'error';
        if (line.includes('MASTER') || line.includes('MIDNIGHT')) return 'master';
        return 'info';
